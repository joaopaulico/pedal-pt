---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Janes, Pisão, Atrozela"
  description="Rota de 10.84 km em Sintra-Cascais com 240m de subida. Loop técnico com descidas desafiantes e vistas sobre os campos."
  image="/images/rotas/janes/og.jpg"
  type="article"
>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <!-- SECTION 1: HERO TITLE -->
  <section class="w-full bg-[#0a0a0a] px-6 pt-32 pb-10">
    <div class="max-w-4xl mx-auto">
      <p class="font-mono text-[10px] tracking-widest uppercase mb-4" style="color: #44b687; font-family: 'Inter', sans-serif;">Rotas · Sintra-Cascais</p>
      <h1 class="text-4xl md:text-6xl font-semibold text-white mb-4 leading-none" style="font-family: 'Sora', sans-serif; letter-spacing: -0.03em;">
        Janes, Pisão,<br>Atrozela
      </h1>
      <p class="text-neutral-400 text-lg" style="font-family: 'Inter', sans-serif;">
        10.84 km · 240m ↑ · Loop · Gravel + Estrada · Abril 2026
      </p>
    </div>
  </section>

  <!-- SECTION MAP -->
  <section class="w-full bg-[#0a0a0a] px-6 pb-0">
    <div class="max-w-4xl mx-auto">
      <div id="map" style="height: 480px; border-radius: 12px; overflow: hidden;"></div>
      <p class="text-neutral-600 text-xs mt-2 text-right" style="font-family: 'Inter', sans-serif;">Clica e arrasta para explorar · scroll para zoom</p>
    </div>
  </section>

  <!-- SECTION 2: STATS GRID -->
  <section class="w-full bg-[#0a0a0a] px-6 pt-10 pb-16 md:pb-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        <!-- Distância -->
        <div class="bg-neutral-900 rounded-xl border border-neutral-800 p-6">
          <p class="text-neutral-400 text-sm mb-2" style="font-family: 'Inter', sans-serif;">Distância</p>
          <p class="text-3xl md:text-4xl font-semibold" style="font-family: 'Sora', sans-serif; color: #269b6c;">
            10.84 km
          </p>
        </div>

        <!-- Subida -->
        <div class="bg-neutral-900 rounded-xl border border-neutral-800 p-6">
          <p class="text-neutral-400 text-sm mb-2" style="font-family: 'Inter', sans-serif;">Subida</p>
          <p class="text-3xl md:text-4xl font-semibold" style="font-family: 'Sora', sans-serif; color: #269b6c;">
            240m
          </p>
        </div>

        <!-- Descida -->
        <div class="bg-neutral-900 rounded-xl border border-neutral-800 p-6">
          <p class="text-neutral-400 text-sm mb-2" style="font-family: 'Inter', sans-serif;">Descida</p>
          <p class="text-3xl md:text-4xl font-semibold" style="font-family: 'Sora', sans-serif; color: #269b6c;">
            238m
          </p>
        </div>

        <!-- Elevação Min/Max -->
        <div class="bg-neutral-900 rounded-xl border border-neutral-800 p-6">
          <p class="text-neutral-400 text-sm mb-2" style="font-family: 'Inter', sans-serif;">Elevação</p>
          <p class="text-lg font-semibold" style="font-family: 'Sora', sans-serif; color: #269b6c;">
            68m / 174m
          </p>
          <p class="text-xs text-neutral-500 mt-1">Mín / Máx</p>
        </div>

        <!-- Gradiente -->
        <div class="bg-neutral-900 rounded-xl border border-neutral-800 p-6">
          <p class="text-neutral-400 text-sm mb-2" style="font-family: 'Inter', sans-serif;">Gradiente</p>
          <p class="text-lg font-semibold" style="font-family: 'Sora', sans-serif; color: #269b6c;">
            +12% / -11.8%
          </p>
          <p class="text-xs text-neutral-500 mt-1">Máx subida / descida</p>
        </div>

        <!-- Superfície -->
        <div class="bg-neutral-900 rounded-xl border border-neutral-800 p-6">
          <p class="text-neutral-400 text-sm mb-2" style="font-family: 'Inter', sans-serif;">Superfície</p>
          <p class="text-lg font-semibold" style="font-family: 'Sora', sans-serif; color: #269b6c;">
            Asfalto + Gravel + Calçada
          </p>
        </div>

        <!-- Tipo -->
        <div class="bg-neutral-900 rounded-xl border border-neutral-800 p-6">
          <p class="text-neutral-400 text-sm mb-2" style="font-family: 'Inter', sans-serif;">Tipo</p>
          <p class="text-lg font-semibold" style="font-family: 'Sora', sans-serif; color: #269b6c;">
            Loop
          </p>
          <p class="text-xs text-neutral-500 mt-1">Ponto de partida = chegada</p>
        </div>

        <!-- Bicicleta -->
        <div class="bg-neutral-900 rounded-xl border border-neutral-800 p-6">
          <p class="text-neutral-400 text-sm mb-2" style="font-family: 'Inter', sans-serif;">Bicicleta ideal</p>
          <p class="text-lg font-semibold" style="font-family: 'Sora', sans-serif; color: #269b6c;">
            Gravel / Road
          </p>
          <p class="text-xs text-neutral-500 mt-1">Gravel mais confortável no trilho</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION NARRATIVE: Notas de campo com fotos integradas -->
  <section class="w-full bg-[#111111] px-6 py-12 md:py-20">
    <div class="max-w-3xl mx-auto">
      <p class="font-mono text-[10px] tracking-widest uppercase mb-8" style="color: #44b687; font-family: 'Inter', sans-serif;">Notas de campo</p>

      <p class="text-white text-xl leading-relaxed mb-10" style="font-family: 'Sora', sans-serif; letter-spacing: -0.01em;">
        Manhã de primavera, bom tempo, luz rasante a entrar pela berma. Este loop é curto mas não é simples. É o tipo de saída que preferes ao grande fundo nos dias em que tens hora e meia, não três.
      </p>

      <!-- Parágrafo 1 + foto 01 (direita) -->
      <div style="overflow: hidden; margin-bottom: 2rem;">
        <img src="/images/rotas/janes/01.jpg" alt="Quinta abandonada na calçada portuguesa" loading="lazy"
          style="float: right; width: 32%; margin-left: 1.5rem; margin-bottom: 0.5rem; border-radius: 8px; display: block;" />
        <p style="font-family: 'Inter', sans-serif; line-height: 1.8; color: #a3a3a3;">
          A partida de Janes desce logo, o que é bom para as pernas mas traiçoeiro para a cabeça: sabes que tudo o que desces tens de subir. Nos primeiros quilómetros o asfalto está limpo e a estrada é larga. Logo no início aparece uma quinta abandonada na calçada, o tipo de coisa que Sintra guarda a poucos metros de qualquer estrada.
        </p>
      </div>

      <!-- Parágrafo 2 + foto 02 (esquerda) -->
      <div style="overflow: hidden; margin-bottom: 2rem;">
        <img src="/images/rotas/janes/02.jpg" alt="Estrada de pinheiros em Sintra" loading="lazy"
          style="float: left; width: 32%; margin-right: 1.5rem; margin-bottom: 0.5rem; border-radius: 8px; display: block;" />
        <p style="font-family: 'Inter', sans-serif; line-height: 1.8; color: #a3a3a3;">
          A descida para Pisão tem curvas fechadas e é rápida. O tipo em que convém ter os freios em bom estado e os pneus com grip decente. No meio do caminho, asfalto limpo entre pinheiros altos. O tipo de estrada onde se pisa fundo sem pensar duas vezes.
        </p>
      </div>

      <!-- Parágrafo 3 + foto 03 (direita) -->
      <div style="overflow: hidden; margin-bottom: 2rem;">
        <img src="/images/rotas/janes/03.jpg" alt="Caminho de gravel com flores amarelas" loading="lazy"
          style="float: right; width: 32%; margin-left: 1.5rem; margin-bottom: 0.5rem; border-radius: 8px; display: block;" />
        <p style="font-family: 'Inter', sans-serif; line-height: 1.8; color: #a3a3a3;">
          O trecho de gravel aparece depois de Atrozela. Terreno solto mas compacto, perfeitamente transitável numa road com 28mm. Numa gravel é ainda mais confortável. É aqui que as vistas sobre os campos abrem: flores amarelas, verde intenso, silêncio. Se tens câmara, para.
        </p>
      </div>

      <!-- Parágrafo 4 + foto 04 (esquerda) -->
      <div style="overflow: hidden; margin-bottom: 2rem;">
        <img src="/images/rotas/janes/04.jpg" alt="Campos de flores com a Serra ao fundo" loading="lazy"
          style="float: left; width: 32%; margin-right: 1.5rem; margin-bottom: 0.5rem; border-radius: 8px; display: block;" />
        <p style="font-family: 'Inter', sans-serif; line-height: 1.8; color: #a3a3a3;">
          A Serra de Sintra no horizonte, campos em flor na primavera. É aqui que percebes porque é que vale a pena ter gravel. A subida final é a mais gentil da rota: sustentada e previsível, 3 a 5%, o tipo que consegues manter sem explodir. Chegas ao ponto de partida com as pernas cansadas mas sem a sensação de ter sido destruído.
        </p>
      </div>

      <!-- Foto 05 panorama full-width -->
      <div style="margin-bottom: 2rem;">
        <img src="/images/rotas/janes/05.jpg" alt="Arco-íris completo sobre os campos de Atrozela" loading="lazy"
          style="width: 100%; border-radius: 8px; display: block; margin-bottom: 0.75rem;" />
        <p style="font-family: 'Inter', sans-serif; font-size: 0.8rem; color: #525252; text-align: right;">Atrozela, Abril 2026</p>
      </div>

      <div class="border-l-4 border-[#269b6c] pl-6 mt-10">
        <p class="text-neutral-300 italic" style="font-family: 'Inter', sans-serif; line-height: 1.8;">
          "Uma hora e meia de Sintra que vale qualquer saída longa. Terreno variado, pouco trânsito, e aquele trecho de gravel antes de Atrozela que ninguém esperaria encontrar aqui."
        </p>
        <p class="text-neutral-500 text-sm mt-3" style="font-family: 'Inter', sans-serif;">João · Abril 2026 · Bom tempo, 18°C</p>
      </div>
    </div>
  </section>

  <!-- SECTION 3: ELEVATION PROFILE -->
  <section class="w-full bg-[#faf9f7] px-6 py-12 md:py-16">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-semibold mb-8" style="font-family: 'Sora', sans-serif; color: #0a0a0a;">
        Perfil de Elevação
      </h2>

      <div class="relative bg-white rounded-lg border border-neutral-200 p-4 md:p-6">
        <svg id="elevationProfile" class="w-full" viewBox="0 0 1200 300" preserveAspectRatio="xMidYMid meet"></svg>

        <div id="tooltip" class="absolute hidden bg-neutral-900 text-white px-3 py-2 rounded text-sm pointer-events-none" style="font-family: 'Inter', sans-serif;">
          <div id="tooltipContent"></div>
        </div>
      </div>

      <div class="mt-6 grid grid-cols-2 md:grid-cols-5 gap-3 text-sm" style="font-family: 'Inter', sans-serif;">
        <div class="text-neutral-700">
          <span class="font-semibold text-[#269b6c]">0 km</span>
          <p class="text-xs text-neutral-500">Janes</p>
        </div>
        <div class="text-neutral-700">
          <span class="font-semibold text-[#e67e22]">2.3 km</span>
          <p class="text-xs text-neutral-500">Descida Pisão</p>
        </div>
        <div class="text-neutral-700">
          <span class="font-semibold text-[#c8553d]">3.1 km</span>
          <p class="text-xs text-neutral-500">Subida Atrozela</p>
        </div>
        <div class="text-neutral-700">
          <span class="font-semibold text-[#d4a843]">8.1 km</span>
          <p class="text-xs text-neutral-500">Ponto mais baixo</p>
        </div>
        <div class="text-neutral-700">
          <span class="font-semibold text-[#269b6c]">10.8 km</span>
          <p class="text-xs text-neutral-500">Regresso Janes</p>
        </div>
      </div>
    </div>
  </section>


  <!-- SECTION 5: KM-BY-KM BREAKDOWN -->
  <section class="w-full bg-[#faf9f7] px-6 py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-semibold mb-8" style="font-family: 'Sora', sans-serif; color: #0a0a0a;">
        Km a km
      </h2>

      <div class="space-y-4">
        <!-- Segment 1 -->
        <div class="bg-white rounded-lg border-l-4 border-[#44b687] p-6">
          <p class="text-sm font-semibold text-[#269b6c] mb-1" style="font-family: 'Sora', sans-serif;">
            km 0.0–0.9
          </p>
          <p class="text-neutral-900 font-medium mb-2" style="font-family: 'Sora', sans-serif;">
            Descida suave de Janes
          </p>
          <p class="text-neutral-600 text-sm" style="font-family: 'Inter', sans-serif;">
            -2% a -6% • Asfalto bom • Aquecimento natural
          </p>
        </div>

        <!-- Segment 2 -->
        <div class="bg-white rounded-lg border-l-4 border-[#d4a843] p-6">
          <p class="text-sm font-semibold text-[#d4a843] mb-1" style="font-family: 'Sora', sans-serif;">
            km 0.9–1.8
          </p>
          <p class="text-neutral-900 font-medium mb-2" style="font-family: 'Sora', sans-serif;">
            Ondulação com subidas curtas
          </p>
          <p class="text-neutral-600 text-sm" style="font-family: 'Inter', sans-serif;">
            Variável • Terreno diversificado • Preparação mental
          </p>
        </div>

        <!-- Segment 3 -->
        <div class="bg-white rounded-lg border-l-4 border-[#c8553d] p-6">
          <p class="text-sm font-semibold text-[#c8553d] mb-1" style="font-family: 'Sora', sans-serif;">
            km 1.8–2.5
          </p>
          <p class="text-neutral-900 font-medium mb-2" style="font-family: 'Sora', sans-serif;">
            Descida forte de Pisão
          </p>
          <p class="text-neutral-600 text-sm" style="font-family: 'Inter', sans-serif;">
            -7% a -12% • Velocidade alta • Cuidado nas curvas fechadas
          </p>
        </div>

        <!-- Segment 4 -->
        <div class="bg-white rounded-lg border-l-4 border-[#c8553d] p-6">
          <p class="text-sm font-semibold text-[#c8553d] mb-1" style="font-family: 'Sora', sans-serif;">
            km 2.5–3.4
          </p>
          <p class="text-neutral-900 font-medium mb-2" style="font-family: 'Sora', sans-serif;">
            Subida intensa de Atrozela
          </p>
          <p class="text-neutral-600 text-sm" style="font-family: 'Inter', sans-serif;">
            +6% a +12% • O ponto duro da rota • Muro final mas curto
          </p>
        </div>

        <!-- Segment 5 -->
        <div class="bg-white rounded-lg border-l-4 border-[#d4a843] p-6">
          <p class="text-sm font-semibold text-[#d4a843] mb-1" style="font-family: 'Sora', sans-serif;">
            km 3.4–5.0
          </p>
          <p class="text-neutral-900 font-medium mb-2" style="font-family: 'Sora', sans-serif;">
            Descida progressiva na zona de Pisão
          </p>
          <p class="text-neutral-600 text-sm" style="font-family: 'Inter', sans-serif;">
            Variável • Ondulação • Recuperação ativa
          </p>
        </div>

        <!-- Segment 6 -->
        <div class="bg-white rounded-lg border-l-4 border-[#44b687] p-6">
          <p class="text-sm font-semibold text-[#269b6c] mb-1" style="font-family: 'Sora', sans-serif;">
            km 5.0–8.0
          </p>
          <p class="text-neutral-900 font-medium mb-2" style="font-family: 'Sora', sans-serif;">
            Descida longa até ao ponto mais baixo
          </p>
          <p class="text-neutral-600 text-sm" style="font-family: 'Inter', sans-serif;">
            Progressiva • Ritmo confortável • 68m de elevação mínima
          </p>
        </div>

        <!-- Segment 7 -->
        <div class="bg-white rounded-lg border-l-4 border-[#e67e22] p-6">
          <p class="text-sm font-semibold text-[#e67e22] mb-1" style="font-family: 'Sora', sans-serif;">
            km 8.0–10.8
          </p>
          <p class="text-neutral-900 font-medium mb-2" style="font-family: 'Sora', sans-serif;">
            Subida sustentada de regresso
          </p>
          <p class="text-neutral-600 text-sm" style="font-family: 'Inter', sans-serif;">
            +3% a +5% • Consistente e segura • Último esforço controlado
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 6: RECOMMENDATIONS -->
  <section class="w-full bg-[#0a0a0a] px-6 py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-semibold mb-8" style="font-family: 'Sora', sans-serif; color: white;">
        Antes de ir
      </h2>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Gearing -->
        <div class="bg-neutral-900 rounded-lg border border-neutral-800 p-6">
          <h3 class="text-lg font-semibold mb-3" style="font-family: 'Sora', sans-serif; color: #44b687;">
            Gearing
          </h3>
          <p class="text-neutral-300 text-sm" style="font-family: 'Inter', sans-serif;">
            Compact 50/34 com cassete 11-34 cobre tudo. Mudança baixa essencial para o muro de Atrozela. Se tens 11-28, vai ficar apertado.
          </p>
        </div>

        <!-- Quando ir -->
        <div class="bg-neutral-900 rounded-lg border border-neutral-800 p-6">
          <h3 class="text-lg font-semibold mb-3" style="font-family: 'Sora', sans-serif; color: #44b687;">
            Quando ir
          </h3>
          <p class="text-neutral-300 text-sm" style="font-family: 'Inter', sans-serif;">
            Manhã cedo na primavera ou outono. Sol de verão à tarde torna as subidas implacáveis. Evita fim de semana se queres asfalto menos ocupado.
          </p>
        </div>

        <!-- Água -->
        <div class="bg-neutral-900 rounded-lg border border-neutral-800 p-6">
          <h3 class="text-lg font-semibold mb-3" style="font-family: 'Sora', sans-serif; color: #44b687;">
            Água
          </h3>
          <p class="text-neutral-300 text-sm" style="font-family: 'Inter', sans-serif;">
            Sem fontanários no percurso. Levar pelo menos um bidão de 750ml. Duas garrafas é mais seguro em dias quentes.
          </p>
        </div>

        <!-- Atenção -->
        <div class="bg-neutral-900 rounded-lg border border-neutral-800 p-6">
          <h3 class="text-lg font-semibold mb-3" style="font-family: 'Sora', sans-serif; color: #44b687;">
            Atenção
          </h3>
          <p class="text-neutral-300 text-sm" style="font-family: 'Inter', sans-serif;">
            Descida ao km 2.3 com curvas fechadas e muito traçado. Calçada molhada é traiçoeira. Freios em bom estado e pneus com borracha fresca são obrigatórios.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 7: DOWNLOAD -->
  <section class="w-full bg-[#1c1c1c] px-6 py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-semibold mb-8" style="font-family: 'Sora', sans-serif; color: white;">
        Levar no telemóvel
      </h2>

      <div class="flex flex-col md:flex-row gap-4">
        <a href="/gpx/janes-pisao-atrozela.gpx" download class="flex-1 bg-[#269b6c] hover:bg-[#1e7a52] text-white font-semibold py-4 px-6 rounded-lg text-center transition-colors" style="font-family: 'Sora', sans-serif;">
          ↓ Download GPX
        </a>
        <a href="https://www.strava.com/routes/3476173183880132672" target="_blank" rel="noopener noreferrer" class="flex-1 bg-neutral-800 hover:bg-neutral-700 text-white font-semibold py-4 px-6 rounded-lg text-center transition-colors" style="font-family: 'Sora', sans-serif;">
          → Ver no Strava
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER: Author Card -->
  <section class="w-full bg-[#0a0a0a] px-6 py-8 border-t border-neutral-800">
    <div class="max-w-4xl mx-auto flex items-center gap-4">
      <div class="w-12 h-12 rounded-full bg-[#269b6c] flex items-center justify-center text-white font-bold text-lg" style="font-family: 'Sora', sans-serif;">
        J
      </div>
      <div>
        <p class="font-semibold text-white" style="font-family: 'Sora', sans-serif;">João</p>
        <p class="text-neutral-400 text-sm" style="font-family: 'Inter', sans-serif;">
          Sintra-Cascais, Portugal · Abril 2026
        </p>
      </div>
    </div>
  </section>

  <!-- Leaflet Map Script -->
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
