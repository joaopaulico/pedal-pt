      }
      svg.appendChild(yAxisGroup);

      const axes = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      const xAxis = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      xAxis.setAttribute('x1', padding.left);
      xAxis.setAttribute('y1', height - padding.bottom);
      xAxis.setAttribute('x2', width - padding.right);
      xAxis.setAttribute('y2', height - padding.bottom);
      xAxis.setAttribute('stroke', '#999');
      xAxis.setAttribute('stroke-width', '1');
      axes.appendChild(xAxis);

      const yAxis = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      yAxis.setAttribute('x1', padding.left);
      yAxis.setAttribute('y1', padding.top);
      yAxis.setAttribute('x2', padding.left);
      yAxis.setAttribute('y2', height - padding.bottom);
      yAxis.setAttribute('stroke', '#999');
      yAxis.setAttribute('stroke-width', '1');
      axes.appendChild(yAxis);
      svg.appendChild(axes);

      const tooltip = document.getElementById('tooltip');
      const tooltipContent = document.getElementById('tooltipContent');

      svg.addEventListener('mousemove', function(event) {
        const rect = svg.getBoundingClientRect();
        const mouseX = event.clientX - rect.left;
        const scaleX = width / rect.width;
        const scaledX = mouseX * scaleX;

        if (scaledX < padding.left || scaledX > width - padding.right) {
          tooltip.classList.add('hidden');
          return;
        }

        const km = (scaledX - padding.left) / xScale;
        const closest = PROFILE.reduce((prev, curr) =>
          Math.abs(curr.k - km) < Math.abs(prev.k - km) ? curr : prev
        );

        let gradientPercent = 0;
        const idx = PROFILE.indexOf(closest);
        if (idx < PROFILE.length - 1) {
          const nextPoint = PROFILE[idx + 1];
          const elevDiff = nextPoint.e - closest.e;
          const kmDiff = nextPoint.k - closest.k;
          if (kmDiff > 0) gradientPercent = (elevDiff / (kmDiff * 1000)) * 100;
        }

        tooltipContent.innerHTML = `
          <strong>${closest.k.toFixed(1)} km</strong><br>
          ${closest.e.toFixed(0)} m<br>
          <span style="font-size: 11px; opacity: 0.8;">${gradientPercent > 0 ? '+' : ''}${gradientPercent.toFixed(1)}%</span>
        `;

        tooltip.style.left = (mouseX + 10) + 'px';
        tooltip.style.top = '10px';
        tooltip.classList.remove('hidden');
      });

      svg.addEventListener('mouseleave', function() {
        tooltip.classList.add('hidden');
      });
    });
  </script>
</BaseLayout>
