---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="pedal.pt" description="Ciclismo em Portugal, visto de dentro.">

  <!-- ════════ HERO ════════ -->
  <section class="relative flex flex-col items-center justify-center overflow-hidden bg-[#1c1c1c]" style="min-height: 100vh;">

    <!-- Video container: centered, wide, cinematic crop -->
    <div class="fade-up relative w-full max-w-6xl mx-auto px-6 lg:px-10 pt-28">
      <div class="relative rounded-xl overflow-hidden" style="aspect-ratio: 2.8/1;">
        <video
          autoplay
          muted
          loop
          playsinline
          class="absolute inset-0 w-full h-full object-cover"
        >
          <source src="/video.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-gradient-to-t from-[#1c1c1c]/40 via-transparent to-[#1c1c1c]/20"></div>
      </div>
    </div>

    <!-- Text below video -->
    <div class="relative max-w-6xl mx-auto px-6 lg:px-10 pt-12 pb-6 text-center">
      <h1 class="fade-up delay-1 font-display font-bold text-white leading-tight mb-5" style="font-size: clamp(2.2rem, 4.5vw, 3.5rem); letter-spacing: -0.04em;">
        Pedalar e descobrir Portugal.
      </h1>

      <p class="fade-up delay-2 text-neutral-400 max-w-lg mx-auto" style="font-size: 1rem; line-height: 1.75;">
        Rotas reais, equipamento testado, guias escritos por quem pedala cá o ano inteiro. Sem conversa a mais.
      </p>
    </div>
  </section>

  <!-- ════════ CATEGORIES ════════ -->
  <section class="bg-[#1c1c1c]">
    <div class="max-w-6xl mx-auto px-6 lg:px-10 pt-16 pb-32">
      <div class="fade-up mb-14">
        <p class="font-mono text-[10px] tracking-widest uppercase text-accent-500 mb-2">Categorias</p>
        <h2 class="font-display font-semibold text-white" style="font-size: 1.75rem; letter-spacing: -0.03em;">Explora por tema</h2>
      </div>

      <div class="stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <!-- Artigos -->
        <a href="/blog" class="group relative overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900/50 p-8 flex flex-col justify-end min-h-[180px] hover-lift transition-all hover:border-blue-800 hover:bg-neutral-900">
          <div class="absolute top-0 right-0 w-24 h-24 rounded-full opacity-10 transition-opacity group-hover:opacity-25" style="background: radial-gradient(circle, #60a5fa, transparent 70%);"></div>
          <div class="relative">
            <p class="font-mono text-[10px] tracking-widest uppercase text-blue-400 mb-2">01</p>
            <h3 class="font-display font-semibold text-white text-lg tracking-tight">Artigos</h3>
            <p class="text-neutral-500 text-sm mt-1">Corridas, ciclismo português, o que se passa.</p>
          </div>
        </a>

        <!-- Rotas -->
        <a href="/rotas" class="group relative overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900/50 p-8 flex flex-col justify-end min-h-[180px] hover-lift transition-all hover:border-accent-700 hover:bg-neutral-900">
          <div class="absolute top-0 right-0 w-24 h-24 rounded-full opacity-10 transition-opacity group-hover:opacity-25" style="background: radial-gradient(circle, #269b6c, transparent 70%);"></div>
          <div class="relative">
            <p class="font-mono text-[10px] tracking-widest uppercase text-accent-500 mb-2">02</p>
            <h3 class="font-display font-semibold text-white text-lg tracking-tight">Rotas</h3>
            <p class="text-neutral-500 text-sm mt-1">Percursos detalhados com GPS e fotos reais.</p>
          </div>
        </a>

        <!-- Gear -->
        <a href="/gear" class="group relative overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900/50 p-8 flex flex-col justify-end min-h-[180px] hover-lift transition-all hover:border-yellow-800 hover:bg-neutral-900">
          <div class="absolute top-0 right-0 w-24 h-24 rounded-full opacity-10 transition-opacity group-hover:opacity-25" style="background: radial-gradient(circle, #e8c698, transparent 70%);"></div>
          <div class="relative">
            <p class="font-mono text-[10px] tracking-widest uppercase text-yellow-600 mb-2">03</p>
            <h3 class="font-display font-semibold text-white text-lg tracking-tight">Gear</h3>
            <p class="text-neutral-500 text-sm mt-1">Reviews honestas de equipamento.</p>
          </div>
        </a>

        <!-- Bikepacking -->
        <a href="/categoria/bikepacking" class="group relative overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900/50 p-8 flex flex-col justify-end min-h-[180px] hover-lift transition-all hover:border-accent-800 hover:bg-neutral-900">
          <div class="absolute top-0 right-0 w-24 h-24 rounded-full opacity-10 transition-opacity group-hover:opacity-25" style="background: radial-gradient(circle, #78d1ab, transparent 70%);"></div>
          <div class="relative">
            <p class="font-mono text-[10px] tracking-widest uppercase text-accent-400 mb-2">04</p>
            <h3 class="font-display font-semibold text-white text-lg tracking-tight">Bikepacking</h3>
            <p class="text-neutral-500 text-sm mt-1">Aventuras de vários dias em Portugal.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
