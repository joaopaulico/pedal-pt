---
const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-100 mt-0">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="py-20 grid grid-cols-1 md:grid-cols-12 gap-12">
      <!-- Brand -->
      <div class="md:col-span-4">
        <div class="flex items-center gap-2.5 mb-3">
          <img src="/logo.svg" alt="pedal.pt" class="h-7 w-7" />
          <p class="font-display font-semibold text-lg tracking-tight text-neutral-900">pedal.pt</p>
        </div>
        <p class="text-sm text-neutral-400 leading-relaxed max-w-xs mb-4">
          Ciclismo em Portugal, visto de dentro.
        </p>
        <div class="flex items-center gap-4">
          <a href="https://instagram.com/p3dal.pt" target="_blank" class="text-neutral-300 hover:text-accent-500 transition-colors" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="mailto:geral@pedal.pt" class="text-neutral-300 hover:text-accent-500 transition-colors" aria-label="Email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="3"/><path d="M2 7l10 6 10-6"/></svg>
          </a>
          <a href="/rss.xml" class="text-neutral-300 hover:text-accent-500 transition-colors" aria-label="RSS">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 019 9"/><path d="M4 4a16 16 0 0116 16"/><circle cx="5" cy="19" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
        </div>
      </div>

      <!-- Nav -->
      <div class="md:col-span-2 md:col-start-7">
        <p class="font-mono text-[10px] tracking-widest uppercase text-neutral-300 mb-5">Explorar</p>
        <div class="flex flex-col gap-3">
          <a href="/categoria/rotas" class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors">Rotas</a>
          <a href="/categoria/gear" class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors">Gear</a>
          <a href="/categoria/guias" class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors">Guias</a>
          <a href="/categoria/bikepacking" class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors">Bikepacking</a>
        </div>
      </div>

      <div class="md:col-span-2">
        <p class="font-mono text-[10px] tracking-widest uppercase text-neutral-300 mb-5">Info</p>
        <div class="flex flex-col gap-3">
          <a href="/sobre" class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors">Sobre</a>
          <a href="/contacto" class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors">Contacto</a>
          <a href="/privacidade" class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors">Privacidade</a>
          <a href="/rss.xml" class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors">RSS</a>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="py-6 border-t border-neutral-100 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-[11px] text-neutral-300">&copy; {year} pedal.pt</p>
      <p class="text-[11px] text-neutral-300">Sintra-Cascais, Portugal.</p>
    </div>
  </div>
</footer>
