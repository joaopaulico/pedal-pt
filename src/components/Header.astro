---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/blog', label: 'Artigos' },
  { href: '/categoria/rotas', label: 'Rotas' },
  { href: '/categoria/gear', label: 'Gear' },
  { href: '/categoria/guias', label: 'Guias' },
  { href: '/sobre', label: 'Sobre' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-40 transition-all duration-500">
  <div class="max-w-6xl mx-auto px-5 flex items-center justify-between" style="height: 72px;">

    <a href="/" class="flex items-center gap-2.5 group relative z-10">
      <svg width="30" height="30" viewBox="0 0 30 30" fill="none" class="text-pedal-600 transition-transform duration-500 group-hover:rotate-[60deg]">
        <circle cx="15" cy="15" r="12.5" stroke="currentColor" stroke-width="2"/>
        <circle cx="15" cy="15" r="4.5" fill="currentColor"/>
        <line x1="15" y1="2" x2="15" y2="6.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="15" y1="23.5" x2="15" y2="28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="2" y1="15" x2="6.5" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="23.5" y1="15" x2="28" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <span class="font-display text-xl tracking-tight text-stone-950">pedal<span class="text-gradient">.pt</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`nav-link text-sm tracking-wide transition-colors py-1 ${
            isActive(link.href)
              ? 'text-pedal-700 font-medium active'
              : 'text-stone-400 hover:text-stone-800'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button id="mobile-menu-btn" class="md:hidden relative z-10 w-10 h-10 flex items-center justify-center" aria-label="Menu">
      <div id="hamburger-lines">
        <span class="block w-5 h-px bg-stone-600 transition-all duration-300 origin-center"></span>
        <span class="block w-5 h-px bg-stone-600 transition-all duration-300 mt-1.5"></span>
        <span class="block w-3.5 h-px bg-stone-600 transition-all duration-300 mt-1.5"></span>
      </div>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden overflow-hidden transition-all duration-500 ease-out" style="max-height: 0; opacity: 0;">
    <nav class="max-w-6xl mx-auto px-5 py-6 flex flex-col gap-1">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class={`text-lg py-2.5 transition-all duration-300 ${
            isActive(link.href)
              ? 'text-pedal-700 font-medium'
              : 'text-stone-500 hover:text-stone-900 hover:pl-2'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const lines = document.getElementById('hamburger-lines');
  let menuOpen = false;

  btn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menu) {
      menu.style.maxHeight = menuOpen ? '320px' : '0';
      menu.style.opacity = menuOpen ? '1' : '0';
    }
    if (lines) {
      if (menuOpen) {
        lines.children[0].style.transform = 'translateY(5px) rotate(45deg)';
        lines.children[1].style.opacity = '0';
        lines.children[1].style.transform = 'scaleX(0)';
        lines.children[2].style.width = '20px';
        lines.children[2].style.transform = 'translateY(-7px) rotate(-45deg)';
      } else {
        lines.children[0].style.transform = '';
        lines.children[1].style.opacity = '1';
        lines.children[1].style.transform = '';
        lines.children[2].style.width = '';
        lines.children[2].style.transform = '';
      }
    }
  });

  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('glass');
      header!.style.borderBottom = '1px solid rgba(0,0,0,0.06)';
    } else {
      header?.classList.remove('glass');
      header!.style.borderBottom = 'none';
    }
  }, { passive: true });

  // Scroll reveal observer
  const reveals = document.querySelectorAll('.reveal, .stagger-children');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  reveals.forEach(el => observer.observe(el));
</script>
