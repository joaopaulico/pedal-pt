  <!-- ======================= -->
  <!-- PRODUCT #1: GIRO REGISTER II -->
  <!-- ======================= -->
  <section class="w-full bg-[#0a0a0a] px-6 pt-16 pb-8">
    <div class="max-w-4xl mx-auto">
      <p class="font-mono text-[10px] tracking-widest uppercase mb-2" style="color: #44b687; font-family: 'Inter', sans-serif;">#1</p>
      <h2 class="text-3xl md:text-4xl font-semibold text-white mb-2 leading-tight" style="font-family: 'Sora', sans-serif; letter-spacing: -0.02em;">
        Giro Register II MIPS
