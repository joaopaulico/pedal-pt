---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Rotas · pedal.pt"
  description="Rotas de ciclismo em Portugal com GPS, perfil de elevação, fotos reais e notas de campo."
  image="/og-default.jpg"
>

  <!-- HERO -->
  <section class="w-full bg-[#0a0a0a] px-6 pt-32 pb-16">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center gap-4 mb-8">
        <img src="/pedal-logo.png" alt="pedal.pt" class="w-10 h-10" style="filter: invert(1) brightness(2);" />
      </div>
      <p class="font-mono text-[10px] tracking-widest uppercase mb-4" style="color: #44b687; font-family: 'Inter', sans-serif;">Sintra-Cascais, Portugal</p>
      <h1 class="text-4xl md:text-6xl font-semibold text-white mb-4 leading-none" style="font-family: 'Sora', sans-serif; letter-spacing: -0.03em;">
        Rotas
      </h1>
      <p class="text-neutral-400 text-lg max-w-xl" style="font-family: 'Inter', sans-serif;">
        Percursos detalhados com GPS, perfil de elevação, e notas de campo. Cada rota foi pedalada, fotografada, e escrita por quem a fez.
      </p>
    </div>
  </section>

  <!-- ROUTE CARDS -->
  <section class="w-full bg-[#0a0a0a] px-6 pb-32">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- CARD: Janes, Pisão e Atrozela -->
        <a href="/rotas/janes-pisao-atrozela/" class="group block rounded-2xl overflow-hidden border border-neutral-800 bg-neutral-900/50 transition-all duration-300 hover:border-neutral-600 hover:bg-neutral-900">
          <div class="relative overflow-hidden" style="aspect-ratio: 16/9;">
            <img
              src="/images/rotas/janes/01.jpg"
              alt="Rota Janes, Pisão e Atrozela"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-4 left-5 right-5">
              <p class="font-mono text-[10px] tracking-widest uppercase mb-1" style="color: #44b687; font-family: 'Inter', sans-serif;">Rotas · Sintra-Cascais</p>
              <h2 class="text-xl md:text-2xl font-semibold text-white leading-tight" style="font-family: 'Sora', sans-serif; letter-spacing: -0.02em;">
                Janes, Pisão e Atrozela
              </h2>
            </div>
          </div>
          <div class="p-5 pt-4">
            <p class="text-neutral-400 text-sm mb-4" style="font-family: 'Inter', sans-serif;">
              Sintra profunda por caminhos de terra, aldeias esquecidas e miradouros sobre a serra.
            </p>
            <div class="flex flex-wrap gap-3 text-xs" style="font-family: 'Inter', sans-serif;">
              <span class="bg-neutral-800 text-neutral-300 px-3 py-1 rounded-full">10.84 km</span>
              <span class="bg-neutral-800 text-neutral-300 px-3 py-1 rounded-full">240m ↑</span>
              <span class="bg-neutral-800 text-neutral-300 px-3 py-1 rounded-full">Gravel + Estrada</span>
              <span class="bg-neutral-800 text-neutral-300 px-3 py-1 rounded-full">Loop</span>
            </div>
          </div>
        </a>

        <!-- CARD: Alcabideche, Serra e Mar -->
        <a href="/rotas/alcabideche-serra-mar/" class="group block rounded-2xl overflow-hidden border border-neutral-800 bg-neutral-900/50 transition-all duration-300 hover:border-neutral-600 hover:bg-neutral-900">
          <div class="relative overflow-hidden" style="aspect-ratio: 16/9;">
            <img
              src="/images/rotas/alcabideche-serra-mar/01.jpg"
              alt="Rota Alcabideche, Serra e Mar"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-4 left-5 right-5">
              <p class="font-mono text-[10px] tracking-widest uppercase mb-1" style="color: #44b687; font-family: 'Inter', sans-serif;">Rotas · Sintra-Cascais</p>
              <h2 class="text-xl md:text-2xl font-semibold text-white leading-tight" style="font-family: 'Sora', sans-serif; letter-spacing: -0.02em;">
                Alcabideche, Serra e Mar
              </h2>
            </div>
          </div>
          <div class="p-5 pt-4">
            <p class="text-neutral-400 text-sm mb-4" style="font-family: 'Inter', sans-serif;">
              36.7 km entre Alcabideche e o litoral com 780m de subida. Serra de Sintra, caminhos de floresta, e vista para o Atlântico.
            </p>
            <div class="flex flex-wrap gap-3 text-xs" style="font-family: 'Inter', sans-serif;">
              <span class="bg-neutral-800 text-neutral-300 px-3 py-1 rounded-full">36.7 km</span>
              <span class="bg-neutral-800 text-neutral-300 px-3 py-1 rounded-full">780m ↑</span>
              <span class="bg-neutral-800 text-neutral-300 px-3 py-1 rounded-full">Gravel + Estrada</span>
              <span class="bg-neutral-800 text-neutral-300 px-3 py-1 rounded-full">Exigente</span>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

</BaseLayout>
