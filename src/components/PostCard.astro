---
interface Props {
  title: string;
  excerpt: string;
  slug: string;
  date: Date;
  category: string;
  image?: string;
  featured?: boolean;
}

const { title, excerpt, slug, date, category, image, featured = false } = Astro.props;

const categoryMap: Record<string, { label: string; class: string }> = {
  'rotas': { label: 'Rotas', class: 'category-badge-routes' },
  'gear': { label: 'Gear', class: 'category-badge-gear' },
  'guias': { label: 'Guias', class: 'category-badge-guides' },
  'bikepacking': { label: 'Bikepacking', class: 'category-badge-bikepacking' },
};

const cat = categoryMap[category] || { label: category, class: 'category-badge-guides' };

const formattedDate = date.toLocaleDateString('pt-PT', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<a href={`/blog/${slug}`} class="post-card block">
  {image && (
    <div class={`overflow-hidden rounded-lg mb-4 ${featured ? 'aspect-[16/9]' : 'aspect-[3/2]'}`}>
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
        loading="lazy"
      />
    </div>
  )}

  <div class="flex items-center gap-3 mb-3">
    <span class={`category-badge ${cat.class}`}>{cat.label}</span>
    <time datetime={date.toISOString()} class="text-xs text-stone-400">{formattedDate}</time>
  </div>

  <h3 class={`post-card-title font-display text-stone-950 transition-colors leading-tight mb-2 ${featured ? 'text-3xl' : 'text-xl'}`}>
    {title}
  </h3>

  <p class={`text-stone-500 leading-relaxed ${featured ? 'text-base' : 'text-sm'}`}>
    {excerpt}
  </p>
</a>
