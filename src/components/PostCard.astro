---
interface Props {
  title: string;
  excerpt: string;
  slug: string;
  date: Date;
  category: string;
  image?: string;
  featured?: boolean;
}

const { title, excerpt, slug, date, category, image, featured = false } = Astro.props;

const catLabels: Record<string, string> = {
  'rotas': 'Rotas',
  'gear': 'Gear',
  'guias': 'Guias',
  'bikepacking': 'Bikepacking',
};

const formattedDate = date.toLocaleDateString('pt-PT', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<a href={`/blog/${slug}`} class="group block">
  {image && (
    <div class="img-reveal aspect-[3/2] mb-5">
      <img src={image} alt={title} class="w-full h-full object-cover" loading="lazy" />
    </div>
  )}

  <div class="flex items-center gap-3 mb-3">
    <span class="font-mono text-[10px] tracking-widest uppercase text-accent-500">{catLabels[category] || category}</span>
    <span class="text-neutral-200">/</span>
    <time datetime={date.toISOString()} class="text-xs text-neutral-300">{formattedDate}</time>
  </div>

  <h3 class="font-display font-semibold text-neutral-900 leading-snug mb-2 transition-colors duration-300 group-hover:text-accent-600" style="letter-spacing: -0.02em;">
    {title}
  </h3>

  <p class="text-sm text-neutral-400 leading-relaxed line-clamp-2">
    {excerpt}
  </p>
</a>
