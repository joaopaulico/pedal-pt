---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  category: string;
  tags?: string[];
  image?: string;
  readingTime?: number;
}

const { title, description, date, updated, category, tags = [], image, readingTime } = Astro.props;

const categoryMap: Record<string, { label: string; class: string; href: string }> = {
  'rotas': { label: 'Rotas', class: 'category-badge-routes', href: '/categoria/rotas' },
  'gear': { label: 'Gear', class: 'category-badge-gear', href: '/categoria/gear' },
  'guias': { label: 'Guias', class: 'category-badge-guides', href: '/categoria/guias' },
  'bikepacking': { label: 'Bikepacking', class: 'category-badge-bikepacking', href: '/categoria/bikepacking' },
};

const cat = categoryMap[category] || { label: category, class: 'category-badge-guides', href: '#' };

const formattedDate = date.toLocaleDateString('pt-PT', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={title} description={description} image={image} type="article">

  <!-- Reading progress bar -->
  <div id="reading-progress" class="reading-progress" style="width: 0%"></div>

  <article>
    <!-- Hero image -->
    {image && (
      <div class="w-full max-w-5xl mx-auto px-5 mt-8">
        <div class="aspect-[21/9] rounded-2xl overflow-hidden shadow-xl">
          <img src={image} alt={title} class="w-full h-full object-cover" />
        </div>
      </div>
    )}

    <!-- Header -->
    <header class="max-w-2xl mx-auto px-5 mt-12 mb-12">
      <div class="reveal flex items-center gap-3 mb-6">
        <a href={cat.href} class={`category-badge ${cat.class} hover:opacity-80 transition-opacity`}>
          {cat.label}
        </a>
        <span class="text-stone-200">|</span>
        <time datetime={date.toISOString()} class="text-sm text-stone-400">{formattedDate}</time>
        {readingTime && (
          <>
            <span class="text-stone-200">|</span>
            <span class="text-sm text-stone-400">{readingTime} min</span>
          </>
        )}
      </div>

      <h1 class="reveal reveal-delay-1 font-display text-stone-950 leading-[1.1] mb-6" style="font-size: clamp(2rem, 4.5vw, 3.25rem);">
        {title}
      </h1>

      <p class="reveal reveal-delay-2 text-lg text-stone-400 leading-relaxed" style="font-size: 1.15rem;">
        {description}
      </p>
    </header>

    <!-- Body -->
    <div class="max-w-2xl mx-auto px-5 prose">
      <slot />
    </div>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="max-w-2xl mx-auto px-5 mt-16 pt-8 border-t border-stone-200/60">
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="text-xs text-stone-400 bg-stone-100 px-3 py-1.5 rounded-full hover:bg-stone-200 transition-colors cursor-default">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Author card -->
    <div class="max-w-2xl mx-auto px-5 mt-12 mb-20">
      <div class="relative overflow-hidden bg-gradient-to-br from-stone-100/80 to-stone-50 rounded-2xl p-7 border border-stone-200/50">
        <div class="absolute top-0 right-0 w-32 h-32 bg-pedal-200/20 rounded-full blur-2xl"></div>
        <div class="relative flex items-start gap-5">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-pedal-500 to-pedal-700 flex items-center justify-center flex-shrink-0 shadow-lg shadow-pedal-600/20">
            <span class="font-display text-white text-xl">J</span>
          </div>
          <div>
            <p class="font-medium text-stone-900 mb-1">Escrito por João</p>
            <p class="text-sm text-stone-500 leading-relaxed mb-3">
              Baseado em Sintra-Cascais. Pedala por estas estradas durante o ano todo e escreve sobre o que encontra.
            </p>
            <a href="/sobre" class="text-sm text-pedal-600 hover:text-pedal-700 transition-colors nav-link inline-block">
              Saber mais
            </a>
          </div>
        </div>
      </div>
    </div>
  </article>

  <script>
    // Reading progress
    const bar = document.getElementById('reading-progress');
    if (bar) {
      window.addEventListener('scroll', () => {
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = (window.scrollY / docHeight) * 100;
        bar.style.width = Math.min(progress, 100) + '%';
      }, { passive: true });
    }
  </script>
</BaseLayout>
