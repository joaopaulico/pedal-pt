---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/blog', label: 'Artigos' },
  { href: '/categoria/rotas', label: 'Rotas' },
  { href: '/categoria/gear', label: 'Gear' },
  { href: '/categoria/guias', label: 'Guias' },
  { href: '/sobre', label: 'Sobre' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="fixed top-0 left-0 right-0 z-50 bg-stone-50/90 backdrop-blur-md border-b border-stone-200/60">
  <div class="max-w-6xl mx-auto px-5 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" class="text-pedal-600 group-hover:text-pedal-700 transition-colors">
        <circle cx="14" cy="14" r="12" stroke="currentColor" stroke-width="2"/>
        <circle cx="14" cy="14" r="4" fill="currentColor"/>
        <line x1="14" y1="2" x2="14" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="14" y1="22" x2="14" y2="26" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="2" y1="14" x2="6" y2="14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="22" y1="14" x2="26" y2="14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <span class="font-display text-xl text-stone-950">pedal<span class="text-pedal-600">.pt</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-7">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm tracking-wide transition-colors ${
            isActive(link.href)
              ? 'text-pedal-700 font-medium'
              : 'text-stone-500 hover:text-stone-900'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button id="mobile-menu-btn" class="md:hidden p-2 text-stone-600 hover:text-stone-900" aria-label="Menu">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="3" y1="6" x2="19" y2="6" stroke-linecap="round"/>
        <line x1="3" y1="11" x2="19" y2="11" stroke-linecap="round"/>
        <line x1="3" y1="16" x2="19" y2="16" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-stone-200/60 bg-stone-50/95 backdrop-blur-md">
    <nav class="max-w-6xl mx-auto px-5 py-4 flex flex-col gap-3">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm py-1.5 transition-colors ${
            isActive(link.href)
              ? 'text-pedal-700 font-medium'
              : 'text-stone-600 hover:text-stone-900'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
