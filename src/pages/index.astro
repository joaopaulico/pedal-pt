---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredPost = sortedPosts.find(p => p.data.featured) || sortedPosts[0];
const recentPosts = sortedPosts.filter(p => p !== featuredPost).slice(0, 6);
---

<BaseLayout title="pedal.pt" description="Ciclismo em Portugal, visto de dentro. Rotas reais, reviews honestas, guias práticos.">

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-stone-50 via-pedal-50/30 to-stone-50"></div>
    <div class="absolute top-20 right-0 w-96 h-96 bg-pedal-200/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-10 w-72 h-72 bg-terra-200/15 rounded-full blur-3xl"></div>

    <div class="relative max-w-6xl mx-auto px-5 pt-24 pb-28">
      <div class="max-w-3xl">
        <div class="reveal">
          <span class="inline-block text-xs font-medium tracking-widest uppercase text-pedal-600 mb-5 px-3 py-1.5 rounded-full bg-pedal-100/60">
            Sintra-Cascais, Portugal
          </span>
        </div>

        <h1 class="reveal reveal-delay-1 font-display text-stone-950 leading-[1.05] mb-7" style="font-size: clamp(2.75rem, 6vw, 5rem);">
          Ciclismo em Portugal,<br/>
          <span class="text-gradient">visto de dentro.</span>
        </h1>

        <p class="reveal reveal-delay-2 text-lg text-stone-400 leading-relaxed max-w-xl mb-10" style="font-size: 1.15rem;">
          Rotas que já pedalei, gear que uso a sério, e guias escritos por quem vive e pedala cá o ano todo. Sem fluff, sem stock photos, sem artigos escritos por quem nunca esteve em Portugal.
        </p>

        <div class="reveal reveal-delay-3 flex items-center gap-4">
          <a href="/blog" class="btn-primary">
            Ler artigos
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/sobre" class="btn-secondary">
            Quem sou eu
          </a>
        </div>
      </div>

      <!-- Stats -->
      <div class="reveal reveal-delay-4 mt-20 grid grid-cols-3 gap-6 max-w-md">
        <div>
          <p class="font-display text-3xl text-stone-950">20+</p>
          <p class="text-xs text-stone-400 mt-1">Rotas detalhadas</p>
        </div>
        <div>
          <p class="font-display text-3xl text-stone-950">5</p>
          <p class="text-xs text-stone-400 mt-1">Regiões cobertas</p>
        </div>
        <div>
          <p class="font-display text-3xl text-stone-950">12+</p>
          <p class="text-xs text-stone-400 mt-1">Reviews de gear</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured post -->
  {featuredPost && (
    <section class="max-w-6xl mx-auto px-5 py-20">
      <div class="reveal">
        <p class="text-xs font-semibold tracking-widest uppercase text-stone-300 mb-8">Destaque</p>
      </div>
      <div class="reveal reveal-delay-1">
        <PostCard
          title={featuredPost.data.title}
          excerpt={featuredPost.data.description}
          slug={featuredPost.slug}
          date={featuredPost.data.date}
          category={featuredPost.data.category}
          image={featuredPost.data.image}
          featured={true}
        />
      </div>
    </section>
  )}

  <!-- Recent posts -->
  {recentPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-5 pb-20">
      <div class="flex items-center justify-between mb-10">
        <p class="text-xs font-semibold tracking-widest uppercase text-stone-300">Artigos recentes</p>
        <a href="/blog" class="text-sm text-pedal-600 hover:text-pedal-700 transition-colors nav-link">
          Ver todos
        </a>
      </div>
      <div class="stagger-children grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {recentPosts.map(post => (
          <PostCard
            title={post.data.title}
            excerpt={post.data.description}
            slug={post.slug}
            date={post.data.date}
            category={post.data.category}
            image={post.data.image}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Categories -->
  <section class="max-w-6xl mx-auto px-5 pb-24">
    <div class="reveal relative overflow-hidden rounded-3xl bg-gradient-to-br from-stone-900 via-stone-800 to-stone-900 p-10 sm:p-14">
      <!-- Decorative -->
      <div class="absolute top-0 right-0 w-80 h-80 bg-pedal-600/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-60 h-60 bg-terra-500/10 rounded-full blur-3xl"></div>

      <div class="relative">
        <h2 class="font-display text-3xl sm:text-4xl text-white mb-3" style="font-weight: 400;">O que vais encontrar aqui</h2>
        <p class="text-stone-400 mb-10 max-w-lg">Quatro tipos de conteúdo, todos baseados em experiência real.</p>

        <div class="stagger-children grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          <a href="/categoria/rotas" class="group bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-pedal-600/20 flex items-center justify-center mb-4">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#5aa885" stroke-width="1.5">
                <path d="M3 17l4-6 3 3 4-5 3 4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="font-medium text-white mb-1.5 group-hover:text-pedal-300 transition-colors">Rotas</h3>
            <p class="text-sm text-stone-400 leading-relaxed">Percursos detalhados com GPS, fotos reais e dicas de quem os pedalou.</p>
          </a>

          <a href="/categoria/gear" class="group bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-terra-600/20 flex items-center justify-center mb-4">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#e38f55" stroke-width="1.5">
                <circle cx="10" cy="10" r="7"/>
                <circle cx="10" cy="10" r="2.5"/>
              </svg>
            </div>
            <h3 class="font-medium text-white mb-1.5 group-hover:text-terra-300 transition-colors">Reviews de Gear</h3>
            <p class="text-sm text-stone-400 leading-relaxed">Opiniões honestas sobre equipamento testado nas estradas portuguesas.</p>
          </a>

          <a href="/categoria/guias" class="group bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-stone-600/20 flex items-center justify-center mb-4">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#a1917c" stroke-width="1.5">
                <path d="M4 3h12v14H4z"/>
                <path d="M7 7h6M7 10h4" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="font-medium text-white mb-1.5 group-hover:text-stone-300 transition-colors">Guias</h3>
            <p class="text-sm text-stone-400 leading-relaxed">Informação prática: segurança, clima, logística, aluguer de bicicletas.</p>
          </a>

          <a href="/categoria/bikepacking" class="group bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-pedal-600/15 flex items-center justify-center mb-4">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#88c3a7" stroke-width="1.5">
                <path d="M5 16l3-12h4l3 12" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M7 10h6" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="font-medium text-white mb-1.5 group-hover:text-pedal-300 transition-colors">Bikepacking</h3>
            <p class="text-sm text-stone-400 leading-relaxed">Rotas de vários dias, gear de touring, e aventuras de bicicleta.</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="max-w-6xl mx-auto px-5 pb-24">
    <div class="reveal text-center max-w-lg mx-auto">
      <h2 class="font-display text-2xl text-stone-950 mb-3">Novos artigos na caixa de correio</h2>
      <p class="text-stone-400 text-sm mb-6">Sem spam, só artigos novos. Uma vez por semana, no máximo.</p>
      <div class="flex gap-2 max-w-sm mx-auto">
        <input
          type="email"
          placeholder="o-teu@email.com"
          class="flex-1 px-4 py-3 rounded-xl border border-stone-200 text-sm bg-white focus:outline-none focus:border-pedal-400 focus:ring-2 focus:ring-pedal-100 transition-all"
        />
        <button class="btn-primary px-5 whitespace-nowrap">
          Subscrever
        </button>
      </div>
    </div>
  </section>

</BaseLayout>
