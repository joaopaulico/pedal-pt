---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return [
    { params: { category: 'rotas' } },
    { params: { category: 'gear' } },
    { params: { category: 'guias' } },
    { params: { category: 'bikepacking' } },
  ];
}

const { category } = Astro.params;

const info: Record<string, { title: string; desc: string }> = {
  'rotas': { title: 'Rotas', desc: 'Percursos detalhados para road, gravel e MTB em Portugal.' },
  'gear': { title: 'Gear', desc: 'Reviews honestas de equipamento testado nas condições portuguesas.' },
  'guias': { title: 'Guias', desc: 'Informação prática para pedalar em Portugal.' },
  'bikepacking': { title: 'Bikepacking', desc: 'Rotas de vários dias e gear de touring.' },
};

const { title, desc } = info[category!] || { title: category, desc: '' };

const posts = await getCollection('blog', ({ data }) => !data.draft && data.category === category);
const sorted = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={title} description={desc}>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-neutral-100 via-white to-white" style="height: 300px;"></div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-10 pt-32 pb-32">
      <div class="fade-up mb-16">
        <p class="font-mono text-[10px] tracking-widest uppercase text-accent-500 mb-4">{title}</p>
        <h1 class="font-display font-bold text-neutral-900 leading-none mb-3" style="font-size: clamp(2rem, 4vw, 2.75rem); letter-spacing: -0.035em;">
          {title}
        </h1>
        <p class="text-neutral-400 max-w-md">{desc}</p>
      </div>

      {sorted.length === 0 ? (
        <p class="text-neutral-400 text-center py-24">Em breve.</p>
      ) : (
        <div class="stagger grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-14">
          {sorted.map(post => (
            <PostCard
              title={post.data.title}
              excerpt={post.data.description}
              slug={post.slug}
              date={post.data.date}
              category={post.data.category}
              image={post.data.image}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
