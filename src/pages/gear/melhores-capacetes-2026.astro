            <tr class="border-t border-neutral-800">
              <td class="text-neutral-500 py-3 pr-4">Peso</td>
              <td class="text-neutral-300 py-3 px-4">280g</td>
              <td class="text-neutral-300 py-3 px-4 font-semibold" style="color: #44b687;">250g</td>
              <td class="text-neutral-300 py-3 px-4">290g</td>
              <td class="text-neutral-300 py-3 px-4">279g</td>
