---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/blog', label: 'Artigos' },
  { href: '/categoria/rotas', label: 'Rotas' },
  { href: '/gear', label: 'Gear' },
  { href: '/sobre', label: 'Sobre' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-40 transition-all duration-700" style="border-bottom: 1px solid transparent;">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between" style="height: 80px;">

    <a href="/" class="flex items-center gap-2.5 transition-opacity hover:opacity-60">
      <img src="/logo.svg" alt="pedal.pt" class="h-8 w-8" />
      <span class="font-display font-semibold text-lg tracking-tight text-neutral-900">pedal.pt</span>
    </a>

    <nav class="hidden md:flex items-center gap-10">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`nav-link text-xs tracking-widest uppercase transition-colors ${
            isActive(link.href)
              ? 'text-neutral-900 font-medium active'
              : 'text-neutral-400 hover:text-neutral-900'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button id="mobile-btn" class="md:hidden w-10 h-10 flex items-center justify-center" aria-label="Menu">
      <div id="burger">
        <span class="block w-5 h-px bg-neutral-800 transition-all duration-300"></span>
        <span class="block w-5 h-px bg-neutral-800 mt-1.5 transition-all duration-300"></span>
      </div>
    </button>
  </div>

  <div id="mobile-nav" class="md:hidden overflow-hidden transition-all duration-500" style="max-height:0;opacity:0;">
    <nav class="max-w-7xl mx-auto px-6 pb-8 pt-2 flex flex-col gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-2xl font-display font-light tracking-tight transition-colors ${
            isActive(link.href) ? 'text-neutral-900' : 'text-neutral-300 hover:text-neutral-900'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-btn');
  const nav = document.getElementById('mobile-nav');
  const burger = document.getElementById('burger');
  let open = false;

  btn?.addEventListener('click', () => {
    open = !open;
    if (nav) { nav.style.maxHeight = open ? '300px' : '0'; nav.style.opacity = open ? '1' : '0'; }
    if (burger) {
      const spans = burger.querySelectorAll('span');
      spans[0].style.transform = open ? 'translateY(3px) rotate(45deg)' : '';
      spans[1].style.transform = open ? 'translateY(-3px) rotate(-45deg)' : '';
    }
  });

  const header = document.getElementById('site-header');
  const isHomepage = window.location.pathname === '/';

  function updateHeader() {
    if (window.scrollY > 60) {
      header?.classList.add('glass');
      header?.classList.remove('header-dark');
      header!.style.borderBottomColor = 'rgba(0,0,0,0.05)';
    } else {
      header?.classList.remove('glass');
      if (isHomepage) header?.classList.add('header-dark');
      header!.style.borderBottomColor = 'transparent';
    }
  }

  if (isHomepage) header?.classList.add('header-dark');
  window.addEventListener('scroll', updateHeader, { passive: true });

  // Intersection observer for fade animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('is-visible'); });
  }, { threshold: 0.08, rootMargin: '0px 0px -60px 0px' });
  document.querySelectorAll('.fade-up, .stagger').forEach(el => observer.observe(el));
</script>
