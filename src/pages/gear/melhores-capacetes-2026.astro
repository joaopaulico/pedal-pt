              <td class="py-3 px-4 font-semibold" style="color: #44b687;">4.8/5</td>
              <td class="py-3 px-4 font-semibold" style="color: #269b6c;">4.4/5</td>
              <td class="py-3 px-4 font-semibold" style="color: #269b6c;">4.5/5</td>
