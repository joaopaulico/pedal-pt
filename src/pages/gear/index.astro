---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Lista manual de gear reviews (adiciona aqui cada nova review)
const reviews = [
  {
    slug: 'melhores-capacetes-2026',
    title: 'Melhores Capacetes Custo-Benefício 2026',
    description: 'Comparativo de 4 capacetes de estrada entre 55€ e 120€, todos com MIPS. Specs, ratings e affiliate links.',
    category: 'Capacetes',
    score: 8.8,
    label: 'Comparativo',
    date: '2026-04-14',
    thumb: '/images/gear/melhores-capacetes-2026/hero.jpg',
  },
  {
    slug: 'canyon-grizl-6',
    title: 'Canyon Grizl 6',
    description: 'A porta de entrada para o gravel com assinatura Canyon. Testada em estradas, trilhos e serra, durante meses.',
    category: 'Gravel Bike',
    score: 7.6,
    label: 'Melhor Entrada no Gravel',
    date: '2026-04-07',
    thumb: '/images/gear/canyon-grizl-6/IMG_0767.jpg',
  },
  {
    slug: 'van-rysel-rcr-r5-bib-shorts',
    title: 'Van Rysel RCR-R 5 Bib Shorts',
    description: 'Testados durante semanas em estradas portuguesas. O veredicto sobre os calções que custam 70€ e envergonham marcas que cobram o triplo.',
    category: 'Calções Bib',
    score: 8.9,
    label: 'Melhor Relação Qualidade-Preço',
    date: '2026-04-05',
    thumb: '/images/gear/van-rysel-rcr-r5/01-back.jpg',
  },
];
---

<BaseLayout title="Gear Reviews" description="Reviews honestas de equipamento de ciclismo, testado em Portugal.">

  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-neutral-100 via-white to-white" style="height: 300px;"></div>

    <div class="relative max-w-5xl mx-auto px-6 lg:px-10 pt-32 pb-32">

      <div class="fade-up mb-16">
        <p class="font-mono text-[10px] tracking-widest uppercase text-accent-500 mb-4">Gear Reviews</p>
        <h1 class="font-display font-bold text-neutral-900 leading-none mb-4" style="font-size: clamp(2rem, 4vw, 2.75rem); letter-spacing: -0.035em;">
          Equipamento testado.
        </h1>
        <p class="text-neutral-400 max-w-xl" style="font-size: 1rem; line-height: 1.75;">
          Cada review é escrita depois de uso real, em estradas portuguesas. Sem patrocínios, sem conflito de interesses.
        </p>
      </div>

      <div class="stagger flex flex-col gap-6">
        {reviews.map(review => (
          <a
            href={`/gear/${review.slug}`}
            class="group flex items-center gap-8 bg-white border border-neutral-150 rounded-2xl p-8 hover:border-accent-200 hover:shadow-sm transition-all duration-300"
            style="border-color: #f0f0ed;"
          >
            <!-- Thumb -->
            <div class="flex-shrink-0 hidden sm:block">
              <img
                src={review.thumb}
                alt={review.title}
                class="rounded-xl object-cover"
                style="width: 96px; height: 96px;"
                loading="lazy"
              />
            </div>

            <!-- Score -->
            <div class="flex-shrink-0 text-center hidden sm:block">
              <div class="font-display font-bold text-neutral-900 leading-none" style="font-size: 3rem; letter-spacing: -0.04em;">{review.score.toFixed(1)}</div>
              <div class="font-mono text-[10px] tracking-widest uppercase text-neutral-300 mt-1">/ 10</div>
            </div>

            <!-- Divider -->
            <div class="hidden sm:block w-px self-stretch bg-neutral-100"></div>

            <!-- Info -->
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-2">
                <span class="font-mono text-[10px] tracking-widest uppercase text-accent-500">{review.category}</span>
                <span class="text-neutral-200 text-xs">/</span>
                <span class="font-mono text-[10px] tracking-widest uppercase text-neutral-300">{review.label}</span>
              </div>
              <h2 class="font-display font-semibold text-neutral-900 mb-2 group-hover:text-accent-600 transition-colors" style="font-size: 1.25rem; letter-spacing: -0.02em;">
                {review.title}
              </h2>
              <p class="text-neutral-400 text-sm leading-relaxed line-clamp-2">{review.description}</p>
            </div>

            <!-- Arrow -->
            <div class="flex-shrink-0 text-neutral-300 group-hover:text-accent-500 transition-colors">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 10h12M10 4l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>
