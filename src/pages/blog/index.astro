---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Artigos" description="Todos os artigos sobre ciclismo em Portugal: rotas, reviews de gear, guias práticos e bikepacking.">
  <section class="max-w-6xl mx-auto px-5 pt-16 pb-20">
    <header class="mb-12">
      <h1 class="font-display text-4xl sm:text-5xl text-stone-950 mb-3">Artigos</h1>
      <p class="text-stone-500 max-w-lg">Tudo o que escrevi sobre pedalar em Portugal. Rotas, gear, guias, e umas quantas histórias pelo meio.</p>
    </header>

    {sortedPosts.length === 0 ? (
      <p class="text-stone-400 text-center py-20">Ainda não há artigos publicados. Em breve.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map(post => (
          <PostCard
            title={post.data.title}
            excerpt={post.data.description}
            slug={post.slug}
            date={post.data.date}
            category={post.data.category}
            image={post.data.image}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
