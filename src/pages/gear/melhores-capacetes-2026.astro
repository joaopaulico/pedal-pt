              <th class="text-left text-white font-semibold pb-4 px-4" style="min-width: 140px;">Giro Register II</th>
              <th class="text-left font-semibold pb-4 px-4" style="min-width: 140px; color: #44b687;">Met Rivale ★</th>
              <th class="text-left text-white font-semibold pb-4 px-4" style="min-width: 140px;">Giro Syntax</th>
              <th class="text-left text-white font-semibold pb-4 px-4" style="min-width: 140px;">Bell Stratus</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-t border-neutral-800">
              <td class="text-neutral-500 py-3 pr-4">Preço</td>
              <td class="text-neutral-300 py-3 px-4">55–65€</td>
              <td class="text-neutral-300 py-3 px-4">80–100€</td>
              <td class="text-neutral-300 py-3 px-4">90–120€</td>
              <td class="text-neutral-300 py-3 px-4">80–110€</td>
